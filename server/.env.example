PORT=5100
NODE_ENV=development

# New, separate Postgres database - do NOT reuse ChaiChakhna's Neon database.
# Free at https://neon.tech (create a new project for RestroOS).
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
DB_SSL=true

JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# One-time bootstrap of the first platform admin account (yourself):
# POST http://localhost:5100/api/v1/platform-admin/auth/bootstrap
# { "fullName": "...", "email": "...", "password": "..." }
# Only works while zero platform admins exist - refuses after the first one.

# Razorpay test-mode keys - get these from https://dashboard.razorpay.com/app/keys
# (toggle to "Test Mode" first). Used for the Card/UPI checkout demo only;
# Cash orders never touch Razorpay.
RAZORPAY_KEY_ID=rzp_test_replace_with_your_key_id
RAZORPAY_KEY_SECRET=replace_with_your_test_key_secret

# Pusher (Channels) - get these from https://dashboard.pusher.com, "App Keys"
# tab of your app. Powers realtime order push (new orders, status changes)
# to tenant-admin/POS and the storefront order-tracking page. Optional -
# without these the app falls back to its existing polling.
PUSHER_APP_ID=replace_with_your_pusher_app_id
PUSHER_KEY=replace_with_your_pusher_key
PUSHER_SECRET=replace_with_your_pusher_secret
PUSHER_CLUSTER=ap2

# Resend - get an API key from https://resend.com/api-keys. Powers order
# confirmation/status/cancellation emails to customers. Optional - without
# it, orders still work, customers just don't get emailed. NOTIFICATION_FROM_EMAIL
# defaults to Resend's own onboarding@resend.dev sender if unset (works
# without verifying a custom domain, fine for testing).
RESEND_API_KEY=replace_with_your_resend_api_key
NOTIFICATION_FROM_EMAIL=RestroOS <onboarding@resend.dev>
