PORT=5100
NODE_ENV=development

# New, separate Postgres database - do NOT reuse ChaiChakhna's Neon database.
# Free at https://neon.tech (create a new project for RestroOS).
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
DB_SSL=true

JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# One-time bootstrap of the first platform admin account (yourself):
# POST http://localhost:5100/api/v1/platform-admin/auth/bootstrap
# { "fullName": "...", "email": "...", "password": "..." }
# Only works while zero platform admins exist - refuses after the first one.
